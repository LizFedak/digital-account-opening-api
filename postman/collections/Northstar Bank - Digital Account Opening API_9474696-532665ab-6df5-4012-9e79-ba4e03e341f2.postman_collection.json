                  "pm.test('GET /account-applications — should support status filtering and pagination', function () {\n  pm.response.to.have.status(200);\n});\nconst json = pm.response.json();\npm.test('Filtered list should return only submitted applications', function () {\n  pm.expect(json.data).to.be.an('array');\n  json.data.forEach((app) => pm.expect(app.status).to.eql('submitted'));\n  pm.expect(json.meta.limit).to.eql(10);\n  pm.expect(json.meta.offset).to.eql(0);\n});\npm.test('List item data types should match contract', function () {\n  if (json.data.length > 0) {\n    pm.expect(json.data[0].applicationId).to.be.a('string');\n    pm.expect(json.data[0].riskScore).to.be.a('number');\n    pm.expect(json.data[0].funding.initialDepositAmount).to.be.a('number');\n  }\n});"
