        {
          "name": "GET /account-applications/:id — should retrieve the newly created application",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('GET /account-applications/:id — should return 200 for created application', function () {\n  pm.response.to.have.status(200);\n});\nconst json = pm.response.json();\npm.test('Response should include account application envelope', function () {\n  pm.expect(json).to.have.property('data');\n  pm.expect(json).to.have.nested.property('meta.correlationId');\n});\npm.test('Retrieved ID should match collection variable', function () {\n  pm.expect(json.data.applicationId).to.eql(pm.collectionVariables.get('createdApplicationId'));\n});\npm.test('Application should still be submitted before status update', function () {\n  pm.expect(json.data.status).to.eql('submitted');\n  pm.expect(json.data.primaryApplicant.email).to.eql(pm.collectionVariables.get('uniqueEmail'));\n});"
                ]
              }
            }
