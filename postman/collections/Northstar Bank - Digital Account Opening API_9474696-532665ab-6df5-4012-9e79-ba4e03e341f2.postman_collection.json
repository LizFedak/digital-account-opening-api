  "item": [
    {
      "name": "📁 E2E Workflow",
      "item": [
        {
          "name": "POST /account-applications — should create a new application and return 201",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "id": "10328d47-e3cf-40ac-b57f-f934a88daee0",
                "exec": [
                  "const suffix = Date.now();",
                  "pm.collectionVariables.set('uniqueEmail', `e2e.applicant.${suffix}@example.com`);",
                  "console.log(`[Northstar Demo] Generated E2E applicant email ${pm.collectionVariables.get('uniqueEmail')}`);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "id": "9970b5a3-f497-494f-a4b1-ed66ecc06c24",
                "exec": [
                  "pm.test('POST /account-applications — should create a new application and return 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Response should include data and meta envelopes', function () {",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json).to.have.property('meta');",
                  "  pm.expect(json.meta).to.have.property('correlationId');",
                  "  pm.expect(json.meta).to.have.property('timestamp');",
                  "});",
                  "pm.test('Application contract should include all OAS fields', function () {",
                  "  const app = json.data;",
                  "  ['applicationId', 'status', 'productCode', 'accountType', 'primaryApplicant', 'identityVerification', 'funding', 'riskScore', 'submittedAt', 'updatedAt'].forEach((field) => pm.expect(app).to.have.property(field));",
                  "  ['firstName', 'lastName', 'email', 'phone', 'dateOfBirth', 'taxResidency', 'address'].forEach((field) => pm.expect(app.primaryApplicant).to.have.property(field));",
                  "  ['line1', 'city', 'state', 'postalCode', 'country'].forEach((field) => pm.expect(app.primaryApplicant.address).to.have.property(field));",
                  "  ['method', 'documentType', 'documentLastFour', 'verificationStatus'].forEach((field) => pm.expect(app.identityVerification).to.have.property(field));",
                  "  ['initialDepositAmount', 'fundingMethod', 'externalAccountLastFour'].forEach((field) => pm.expect(app.funding).to.have.property(field));",
                  "});",
                  "pm.test('Created application should have submitted status and pending verification', function () {",
                  "  pm.expect(json.data.status).to.eql('submitted');",
                  "  pm.expect(json.data.identityVerification.verificationStatus).to.eql('pending');",
                  "  pm.expect(json.data.riskScore).to.be.a('number');",
                  "});",
                  "pm.collectionVariables.set('createdApplicationId', json.data.applicationId);",
                  "pm.collectionVariables.set('applicationId', json.data.applicationId);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
