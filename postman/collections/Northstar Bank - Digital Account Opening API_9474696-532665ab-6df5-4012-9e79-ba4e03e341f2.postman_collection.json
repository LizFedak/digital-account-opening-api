                "type": "text/javascript",
                "exec": [
                  "pm.test('GET /account-applications/:id — should verify final approved state', function () {\n  pm.response.to.have.status(200);\n});\nconst json = pm.response.json();\npm.test('Final state should be approved', function () {\n  pm.expect(json.data.applicationId).to.eql(pm.collectionVariables.get('createdApplicationId'));\n  pm.expect(json.data.status).to.eql('approved');\n  pm.expect(json.data.identityVerification.verificationStatus).to.eql('verified');\n});\npm.test('Final response should satisfy contract shape', function () {\n  pm.expect(json.data.riskScore).to.be.a('number');\n  pm.expect(json.data.funding.initialDepositAmount).to.be.a('number');\n  pm.expect(json.meta.correlationId).to.be.a('string');\n});"
