              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('PATCH /account-applications/:id/status — should approve reviewed application', function () {\n  pm.response.to.have.status(200);\n});\nconst json = pm.response.json();\npm.test('Approved application should keep verified identity state', function () {\n  pm.expect(json.data.status).to.eql('approved');\n  pm.expect(json.data.identityVerification.verificationStatus).to.eql('verified');\n  pm.expect(json.data.applicationId).to.eql(pm.collectionVariables.get('createdApplicationId'));\n});\npm.test('Response should include correlation metadata', function () {\n  pm.expect(json).to.have.nested.property('meta.correlationId');\n  pm.expect(json).to.have.nested.property('meta.timestamp');\n});"
                ]
              }
            }
