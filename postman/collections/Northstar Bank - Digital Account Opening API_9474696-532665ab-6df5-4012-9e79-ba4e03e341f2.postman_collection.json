              "listen": "test",
              "script": {
                "id": "449f9fa8-cebd-4d5b-a461-8e687da427d3",
                "exec": [
                  "pm.test('PATCH /account-applications/:id/status — should return 200 for valid transition', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Response should include updated application envelope', function () {",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json).to.have.nested.property('meta.correlationId');",
                  "});",
                  "pm.test('Business logic should set status to in-review and verification to verified', function () {",
                  "  pm.expect(json.data.applicationId).to.eql(pm.collectionVariables.get('createdApplicationId'));",
                  "  pm.expect(json.data.status).to.eql('in-review');",
                  "  pm.expect(json.data.identityVerification.verificationStatus).to.eql('verified');",
                  "});",
                  "pm.test('Updated timestamp should be present', function () {",
                  "  pm.expect(json.data.updatedAt).to.be.a('string');",
                  "});"
                ],
