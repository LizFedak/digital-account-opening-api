              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('GET /account-applications/:id — should return 200 for created application', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Response should include account application envelope', function () {",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json).to.have.nested.property('meta.correlationId');",
                  "});",
                  "pm.test('Retrieved ID should match collection variable', function () {",
                  "  pm.expect(json.data.applicationId).to.eql(pm.collectionVariables.get('createdApplicationId'));",
                  "});",
                  "pm.test('Application should still be submitted before status update', function () {",
                  "  pm.expect(json.data.status).to.eql('submitted');",
                  "  pm.expect(json.data.primaryApplicant.email).to.eql(pm.collectionVariables.get('uniqueEmail'));",
                  "});"
