                "exec": [
                  "pm.test('PATCH /account-applications/:id/status — should return 200 for valid transition', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Response should include updated application envelope', function () {",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json).to.have.nested.property('meta.correlationId');",
                  "});",
                  "pm.test('Business logic should set status to in-review and verification to verified', function () {",
